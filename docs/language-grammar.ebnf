(* Current language grammar implemented by Parser.cpp. *)

program     = { declaration } ;

declaration = importDecl
            | exportDecl
            | structDecl
            | implDecl
            | funDecl
            | letDecl
            | statement ;

statement   = printStmt
            | ifStmt
            | whileStmt
            | forStmt
            | breakStmt
            | continueStmt
            | returnStmt
            | block
            | exprStmt ;

funDecl     = "fun", identifier,
              "(", [ parameters ], ")",
              [ ":", typeExpr ],
              block ;

structDecl  = "struct", identifier,
              "{", [ structFields ], "}" ;

implDecl    = "impl", identifier,
              "{", { methodDecl }, "}" ;

methodDecl  = "fun", identifier,
              "(", [ parameters ], ")",
              [ ":", typeExpr ],
              block ;

structFields = structField,
               { ",", structField } ;

structField = identifier, ":", typeExpr ;

parameters  = parameter,
              { ",", parameter } ;

parameter   = identifier,
              [ ":", typeExpr ] ;

letDecl     = "let", identifier,
              [ ":", typeExpr ],
              "=", expression, ";" ;

importDecl  = "import", string,
              [ "as", identifier ], ";" ;

exportDecl  = "export", identifier,
              { ",", identifier }, ";" ;

ifStmt      = "if", expression, block,
              [ "else", block ] ;

whileStmt   = "while", expression, block ;

forStmt     = "for", ( forInClause | cForClause ), block ;

forInClause = identifier, "in", expression ;

cForClause  = [ forInitializer ], ";",
              [ expression ], ";",
              [ expression ] ;

forInitializer = letForInitializer
               | expression ;

letForInitializer = "let", identifier,
                    [ ":", typeExpr ],
                    "=", expression ;

breakStmt   = "break", ";" ;

continueStmt = "continue", ";" ;

block       = "{", { declaration }, "}" ;

printStmt   = "print", expression, ";" ;

returnStmt  = "return", [ expression ], ";" ;

exprStmt    = expression, ";" ;

expression  = assignment ;

assignment  = logicalOr,
              [ ( "=" | "+=" | "-=" | "*=" | "/=" ), assignment ] ;

assignmentTarget = identifier
                 | call, "[", expression, "]"
                 | call, ".", identifier ;

(* Assignment is right-associative. Plain `=` and compound assignment operators
   accept variable, index, and field targets (`name = value`, `array[index] = value`,
   `object.field = value`, `name += value`, `array[index] += value`, and
   `object.field += value`). Compound assignment is numeric-only. All other left
   sides are parse errors. *)

logicalOr   = logicalAnd,
              { "||", logicalAnd } ;

logicalAnd  = equality,
              { "&&", equality } ;

equality    = comparison,
              { ( "==" | "!=" ), comparison } ;

comparison  = term,
              { ( "<" | "<=" | ">" | ">=" ), term } ;

term        = factor,
              { ( "+" | "-" ), factor } ;

factor      = unary,
              { ( "*" | "/" ), unary } ;

unary       = ( "!" | "-" ), unary
            | call ;

call        = primary,
              { memberCall
              | "(", [ arguments ], ")"
              | "[", expression, "]"
              | ".", identifier } ;

memberCall  = ".", identifier, "(", [ arguments ], ")" ;

arguments   = expression,
              { ",", expression } ;

array       = "[", [ arguments ], "]" ;

struct      = "{", [ fields ], "}" ;

structConstructor = [ identifier, "." ], identifier, "{", [ fields ], "}" ;

fields      = field,
              { ",", field } ;

field       = identifier, ":", expression ;

functionExpr = "fun", "(", [ parameters ], ")",
               [ ":", typeExpr ],
               block ;

primary     = functionExpr
            | "false"
            | "true"
            | "nil"
            | number
            | string
            | array
            | structConstructor
            | struct
            | identifier
            | "(", expression, ")" ;

typeExpr    = nullableType ;

nullableType = primaryType,
               [ "?" ] ;

primaryType = arrayType
            | functionType
            | qualifiedType
            | simpleType ;

arrayType   = "[", typeExpr, "]" ;

simpleType  = identifier ;

qualifiedType = identifier, ".", identifier ;

functionType = "fun", "(", [ typeArguments ], ")", ":", typeExpr ;

(* `T?` means `T` or `nil`. This slice supports nullable function parameter and
   return types, but not nullable function values such as `(fun(number): string)?`. *)

typeArguments = typeExpr,
                { ",", typeExpr } ;
identifier  = letter, { letter | digit | "_" } ;
number      = digit, { digit }, [ ".", digit, { digit } ] ;
string      = '"', { character }, '"' ;
