(* Current language grammar implemented by Parser.cpp. *)

program     = { declaration } ;

declaration = importDecl
            | exportDecl
            | structDecl
            | funDecl
            | letDecl
            | statement ;

statement   = printStmt
            | ifStmt
            | whileStmt
            | breakStmt
            | continueStmt
            | returnStmt
            | block
            | exprStmt ;

funDecl     = "fun", identifier,
              "(", [ parameters ], ")",
              [ ":", typeExpr ],
              block ;

structDecl  = "struct", identifier,
              "{", [ structFields ], "}" ;

structFields = structField,
               { ",", structField } ;

structField = identifier, ":", typeExpr ;

parameters  = parameter,
              { ",", parameter } ;

parameter   = identifier,
              [ ":", typeExpr ] ;

letDecl     = "let", identifier,
              [ ":", typeExpr ],
              "=", expression, ";" ;

importDecl  = "import", string, ";" ;

exportDecl  = "export", ( structDecl | funDecl | letDecl ) ;

ifStmt      = "if", expression, block,
              [ "else", block ] ;

whileStmt   = "while", expression, block ;

breakStmt   = "break", ";" ;

continueStmt = "continue", ";" ;

block       = "{", { declaration }, "}" ;

printStmt   = "print", expression, ";" ;

returnStmt  = "return", [ expression ], ";" ;

exprStmt    = expression, ";" ;

expression  = assignment ;

assignment  = logicalOr, [ "=", assignment ] ;

assignmentTarget = identifier
                 | call, "[", expression, "]"
                 | call, ".", identifier ;

(* Assignment is right-associative. The parser accepts only variable targets and
   index or field targets (`name = value`, `array[index] = value`, and
   `object.field = value`); all other left sides are parse errors. *)

logicalOr   = logicalAnd,
              { "||", logicalAnd } ;

logicalAnd  = equality,
              { "&&", equality } ;

equality    = comparison,
              { ( "==" | "!=" ), comparison } ;

comparison  = term,
              { ( "<" | "<=" | ">" | ">=" ), term } ;

term        = factor,
              { ( "+" | "-" ), factor } ;

factor      = unary,
              { ( "*" | "/" ), unary } ;

unary       = ( "!" | "-" ), unary
            | call ;

call        = primary,
              { "(", [ arguments ], ")"
              | "[", expression, "]"
              | ".", identifier } ;

arguments   = expression,
              { ",", expression } ;

array       = "[", [ arguments ], "]" ;

struct      = "{", [ fields ], "}" ;

structConstructor = identifier, "{", [ fields ], "}" ;

fields      = field,
              { ",", field } ;

field       = identifier, ":", expression ;

functionExpr = "fun", "(", [ parameters ], ")",
               [ ":", typeExpr ],
               block ;

primary     = functionExpr
            | "false"
            | "true"
            | "nil"
            | number
            | string
            | array
            | structConstructor
            | struct
            | identifier
            | "(", expression, ")" ;

typeExpr    = arrayType
            | functionType
            | simpleType ;

arrayType   = "[", typeExpr, "]" ;

simpleType  = identifier ;

functionType = "fun", "(", [ typeArguments ], ")", ":", typeExpr ;

typeArguments = typeExpr,
                { ",", typeExpr } ;
identifier  = letter, { letter | digit | "_" } ;
number      = digit, { digit }, [ ".", digit, { digit } ] ;
string      = '"', { character }, '"' ;
