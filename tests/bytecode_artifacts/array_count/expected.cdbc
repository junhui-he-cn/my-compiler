cdbc 0.1

constants:
  c0 = number 1
  c1 = number 2
  c2 = number 3
  c3 = number 1
  c4 = nil
  c5 = number 2
  c6 = nil

names:
  n0 = "values#0"
  n1 = "values#0"
  n2 = "value#1"
  n3 = "count"
  n4 = "values#0"
  n5 = "value#2"
  n6 = "count"

main registers=10:
  r0 = constant c0
  r1 = constant c1
  r2 = constant c2
  r3 = array [r0, r1, r2]
  store_var n0, r3
  r4 = load_var n1
  r5 = make_function f0
  r6 = native_call n3 [r4, r5]
  print r6
  r7 = load_var n4
  r8 = make_function f1
  r9 = native_call n6 [r7, r8]
  print r9

function f0 name="<lambda>" arity=1 registers=4:
  param 0 = "value#1"
  r0 = load_var n2
  r1 = constant c3
  r2 = greater r0, r1
  return r2
  r3 = constant c4
  return r3

function f1 name="<lambda>" arity=1 registers=4:
  param 0 = "value#2"
  r0 = load_var n5
  r1 = constant c5
  r2 = equal r0, r1
  return r2
  r3 = constant c6
  return r3

