cdbc 0.1

constants:
  c0 = nil
  c1 = nil
  c2 = number 2
  c3 = number 5

names:
  n0 = "add#0"
  n1 = "a#1"
  n2 = "b#2"
  n3 = "add#0"
  n4 = "add#0"

main registers=6:
  r0 = constant c0
  store_var n0, r0
  r1 = make_function f0
  assign_var n3, r1
  r2 = load_var n4
  r3 = constant c2
  r4 = constant c3
  r5 = call r2 [r3, r4]
  print r5

function f0 name="add" arity=2 registers=4:
  param 0 = "a#1"
  param 1 = "b#2"
  r0 = load_var n1
  r1 = load_var n2
  r2 = add r0, r1
  return r2
  r3 = constant c1
  return r3
