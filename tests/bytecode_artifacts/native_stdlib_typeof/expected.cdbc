cdbc 0.1

constants:
  c0 = nil
  c1 = number 1
  c2 = number 1
  c3 = number 1

names:
  n0 = "typeOf"
  n1 = "typeOf"
  n2 = "typeOf"
  n3 = "x"
  n4 = "typeOf"

main registers=10:
  r0 = constant c0
  r1 = native_call n0 [r0]
  print r1
  r2 = constant c1
  r3 = native_call n1 [r2]
  print r3
  r4 = constant c2
  r5 = array [r4]
  r6 = native_call n2 [r5]
  print r6
  r7 = constant c3
  r8 = struct {n3: r7}
  r9 = native_call n4 [r8]
  print r9
