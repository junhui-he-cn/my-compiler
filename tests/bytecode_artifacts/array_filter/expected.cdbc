debug_sources:
  s0 path="tests/bytecode_artifacts/array_filter/input.cd" text="let values: [number] = [1, 2, 3, 4];\nlet threshold: number = 2;\nlet selected: [number] = filter(values, fun (value) {\n  return value > threshold;\n});\nlet evens: [number] = values.filter(fun (value: number): bool {\n  return value == 2 || value == 4;\n});\nlet snapshot: [number] = [1, 2];\nlet kept: [number] = snapshot.filter(fun (value) {\n  push(snapshot, 9);\n  return true;\n});\n\nprint selected;\nprint evens;\nprint kept;\nprint snapshot;\n"

