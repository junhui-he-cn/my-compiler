debug_sources:
  s0 path="tests/bytecode_artifacts/generic_methods/input.cd" text="struct Box { value: number }\n\nimpl Box {\n  fun echo<T>(value: T): T {\n    let copy: T = value;\n    return copy;\n  }\n\n  fun head<T>(values: [T]): T {\n    return values[0];\n  }\n\n  fun make<T>(): T? {\n    return nil;\n  }\n}\n\nlet box: Box = Box { value: 0 };\nprint box.echo<number>(42);\nprint box.echo(\"hello\");\nprint box.head<number>([3, 4]);\nprint box.make<string>();\n"

