  r23 = load_var n15
  r24 = constant c14
  r25 = call r23 [r24]
  print r25

function f0 name="identity" arity=1 registers=2:
  param 0 = "value#1"
  r0 = load_var n1
  return r0
  r1 = constant c1
  return r1

function f1 name="head" arity=1 registers=4:
  param 0 = "values#3"
  r0 = load_var n4
  r1 = constant c3
  r2 = index r0, r1
  return r2
  r3 = constant c4
  return r3

function f2 name="same" arity=2 registers=2:
  param 0 = "left#5"
  param 1 = "right#6"
  r0 = load_var n7
  return r0
  r1 = constant c6
  return r1

debug_sources:
