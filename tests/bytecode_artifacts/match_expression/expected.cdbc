cdbc 0.1

constants:
  c0 = number 4
  c1 = number 1
  c2 = number 0

names:
  n0 = "Option"
  n1 = "Some"
  n2 = "value#0"
  n3 = "value#0"
  n4 = "Option"
  n5 = "Some"
  n6 = "number#1"
  n7 = "number#1"
  n8 = "Option"
  n9 = "None"

main registers=11:
  r0 = constant c0
  r1 = variant n0.n1 [r0]
  store_var n2, r1
  r2 = load_var n3
  r4 = variant_tag r2 n4.n5
  jump_if_false r4, 13
  r5 = variant_field r2 0
  store_var n6, r5
  r6 = load_var n7
  r7 = constant c1
  r8 = add r6, r7
  r3 = move r8
  jump 18
  r9 = variant_tag r2 n8.n9
  jump_if_false r9, 18
  r10 = constant c2
  r3 = move r10
  jump 18
  print r3

debug_sources:
