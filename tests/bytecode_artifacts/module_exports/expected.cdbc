cdbc 0.1

constants:
  c0 = number 39
  c1 = nil
  c2 = number 3
  c3 = nil
  c4 = nil
  c5 = nil

names:
  n0 = "base#0"
  n1 = "add3#1"
  n2 = "x#2"
  n3 = "add3#1"
  n4 = "answer#3"
  n5 = "add3#1"
  n6 = "base#0"
  n7 = "answer#3"
  n8 = "answer#3"

main registers=7:
  r0 = constant c0
  store_var n0, r0
  r1 = constant c1
  store_var n1, r1
  r2 = make_function f0
  assign_var n3, r2
  r3 = constant c4
  store_var n4, r3
  r4 = make_function f1
  assign_var n7, r4
  r5 = load_var n8
  r6 = call r5 []
  print r6

function f0 name="add3" arity=1 registers=4:
  param 0 = "x#2"
  r0 = load_var n2
  r1 = constant c2
  r2 = add r0, r1
  return r2
  r3 = constant c3
  return r3

function f1 name="answer" arity=0 registers=4:
  r0 = load_var n5
  r1 = load_var n6
  r2 = call r0 [r1]
  return r2
  r3 = constant c5
  return r3
