cdbc 0.1

constants:
  c0 = string "a"
  c1 = number 1
  c2 = string "b"
  c3 = number 2
  c4 = string "b"
  c5 = number 20
  c6 = string "c"
  c7 = number 3

names:
  n0 = "left#0"
  n1 = "right#1"
  n2 = "left#0"
  n3 = "right#1"
  n4 = "merge"
  n5 = "left#0"
  n6 = "right#1"
  n7 = "merge"

main registers=16:
  r0 = constant c0
  r1 = constant c1
  r2 = constant c2
  r3 = constant c3
  r4 = map [r0: r1, r2: r3]
  store_var n0, r4
  r5 = constant c4
  r6 = constant c5
  r7 = constant c6
  r8 = constant c7
  r9 = map [r5: r6, r7: r8]
  store_var n1, r9
  r10 = load_var n2
  r11 = load_var n3
  r12 = native_call n4 [r10, r11]
  print r12
  r13 = load_var n5
  r14 = load_var n6
  r15 = native_call n7 [r13, r14]
  print r15

debug_sources:
  s0 path="tests/bytecode_artifacts/map_merge/input.cd" text="let left: map<string, number> = {\"a\": 1, \"b\": 2};\nlet right: map<string, number> = {\"b\": 20, \"c\": 3};\nprint merge(left, right);\nprint left.merge(right);\n"

