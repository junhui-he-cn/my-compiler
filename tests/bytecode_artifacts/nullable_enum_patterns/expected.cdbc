debug_sources:
  s0 path="tests/bytecode_artifacts/nullable_enum_patterns/input.cd" text="enum Option {\n  Some(value: number),\n  None,\n}\n\nfun describe(value: Option?): string {\n  match value {\n    nil => { return \"nil\"; }\n    Option.Some(value) if value > 10 => { return \"large\"; }\n    Option.Some(value) => { return \"some:\" + str(value); }\n    Option.None => { return \"none\"; }\n  }\n}\n\nlet some: Option? = Option.Some(7);\nlet none: Option? = nil;\nprint describe(some);\nprint describe(none);\nprint match some {\n  nil => \"nil\",\n  Option.Some(value) if value > 10 => \"large\",\n  Option.Some(_) => \"some\",\n  Option.None => \"none\",\n};\nprint match none {\n  nil if true => \"guarded nil\",\n  _ => \"fallback\",\n};\n"

