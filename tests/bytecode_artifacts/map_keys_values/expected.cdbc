cdbc 0.1

constants:
  c0 = string "tea"
  c1 = number 3
  c2 = string "coffee"
  c3 = number 5

names:
  n0 = "prices#0"
  n1 = "prices#0"
  n2 = "keys"
  n3 = "prices#0"
  n4 = "values"

main registers=9:
  r0 = constant c0
  r1 = constant c1
  r2 = constant c2
  r3 = constant c3
  r4 = map [r0: r1, r2: r3]
  store_var n0, r4
  r5 = load_var n1
  r6 = native_call n2 [r5]
  print r6
  r7 = load_var n3
  r8 = native_call n4 [r7]
  print r8

debug_sources:
  s0 path="tests/bytecode_artifacts/map_keys_values/input.cd" text="let prices = {\"tea\": 3, \"coffee\": 5};\nprint keys(prices);\nprint prices.values();\n"

debug_locations:
  main 0 = s0:1:15
  main 1 = s0:1:22
  main 2 = s0:1:25
  main 3 = s0:1:35
  main 4 = s0:1:14
  main 5 = s0:1:1
  main 6 = s0:2:12
  main 7 = s0:2:7
  main 8 = s0:2:1
  main 9 = s0:3:7
  main 10 = s0:3:7
  main 11 = s0:3:1
