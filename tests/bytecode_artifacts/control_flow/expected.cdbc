cdbc 0.1

constants:
  c0 = number 0
  c1 = number 2
  c2 = number 1
  c3 = string "one"
  c4 = string "zero"
  c5 = number 1

names:
  n0 = "i#0"
  n1 = "i#0"
  n2 = "i#0"
  n3 = "i#0"
  n4 = "i#0"

main registers=12:
  r0 = constant c0
  store_var n0, r0
  r1 = load_var n1
  r2 = constant c1
  r3 = less r1, r2
  jump_if_false r3, 20
  r4 = load_var n2
  r5 = constant c2
  r6 = equal r4, r5
  jump_if_false r6, 13
  r7 = constant c3
  print r7
  jump 15
  r8 = constant c4
  print r8
  r9 = load_var n3
  r10 = constant c5
  r11 = add r9, r10
  assign_var n4, r11
  jump 2

debug_sources:
  s0 path="tests/bytecode_artifacts/control_flow/input.cd" text="let i = 0;\nwhile i < 2 {\n  if i == 1 {\n    print \"one\";\n  } else {\n    print \"zero\";\n  }\n  i = i + 1;\n}\n"

debug_locations:
  main 0 = s0:1:9
  main 1 = s0:1:1
  main 2 = s0:2:7
  main 3 = s0:2:11
  main 4 = s0:2:7
  main 5 = s0:2:1
  main 6 = s0:3:6
  main 7 = s0:3:11
  main 8 = s0:3:6
  main 9 = s0:3:3
  main 10 = s0:4:11
  main 11 = s0:4:5
  main 12 = s0:3:3
  main 13 = s0:6:11
  main 14 = s0:6:5
  main 15 = s0:8:7
  main 16 = s0:8:11
  main 17 = s0:8:7
  main 18 = s0:8:3
  main 19 = s0:2:1
