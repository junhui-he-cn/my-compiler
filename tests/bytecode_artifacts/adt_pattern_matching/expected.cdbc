cdbc 0.1

constants:
  c0 = number 4
  c1 = number 0

names:
  n0 = "Option"
  n1 = "Some"
  n2 = "value#0"
  n3 = "value#0"
  n4 = "Option"
  n5 = "Some"
  n6 = "number#1"
  n7 = "number#1"
  n8 = "Option"
  n9 = "None"

main registers=8:
  r0 = constant c0
  r1 = variant n0.n1 [r0]
  store_var n2, r1
  r2 = load_var n3
  r3 = variant_tag r2 n4.n5
  jump_if_false r3, 11
  r4 = variant_field r2 0
  store_var n6, r4
  r5 = load_var n7
  print r5
  jump 16
  r6 = variant_tag r2 n8.n9
  jump_if_false r6, 16
  r7 = constant c1
  print r7
  jump 16

debug_sources:
  s0 path="tests/bytecode_artifacts/adt_pattern_matching/input.cd" text="enum Option { Some(number), None }\nlet value = Option.Some(4);\nmatch value {\n  Option.Some(number) => { print number; }\n  Option.None => { print 0; }\n}\n"

debug_locations:
  main 0 = s0:2:25
  main 1 = s0:2:13
  main 2 = s0:2:1
  main 3 = s0:3:7
  main 4 = s0:3:1
  main 5 = s0:3:1
  main 6 = s0:3:1
  main 7 = s0:3:1
  main 8 = s0:4:34
  main 9 = s0:4:28
  main 10 = s0:3:1
  main 11 = s0:3:1
  main 12 = s0:3:1
  main 13 = s0:5:26
  main 14 = s0:5:20
  main 15 = s0:3:1
