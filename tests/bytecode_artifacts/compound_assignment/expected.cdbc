cdbc 0.1

constants:
  c0 = number 1
  c1 = number 2

names:
  n0 = "x#0"
  n1 = "x#0"
  n2 = "`+=` expects number variable"
  n3 = "`+=` expects number value"
  n4 = "x#0"
  n5 = "x#0"

main registers=7:
  r0 = constant c0
  store_var n0, r0
  r1 = load_var n1
  r2 = assert_number r1, n2
  r3 = constant c1
  r4 = assert_number r3, n3
  r5 = add r2, r4
  assign_var n4, r5
  r6 = load_var n5
  print r6

debug_sources:
  s0 path="tests/bytecode_artifacts/compound_assignment/input.cd" text="let x = 1;\nx += 2;\nprint x;\n"

debug_locations:
  main 0 = s0:1:9
  main 1 = s0:1:1
  main 2 = s0:2:1
  main 3 = s0:2:1
  main 4 = s0:2:6
  main 5 = s0:2:1
  main 6 = s0:2:1
  main 7 = s0:2:1
  main 8 = s0:3:7
  main 9 = s0:3:1
