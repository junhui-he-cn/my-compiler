cdbc 0.1

constants:
  c0 = number 1
  c1 = string "x"
  c2 = string "hello"
  c3 = number 1
  c4 = number 3
  c5 = string "hello"
  c6 = number 4

names:
  n0 = "str"
  n1 = "substr"
  n2 = "charAt"

main registers=11:
  r0 = constant c0
  r1 = constant c1
  r2 = array [r0, r1]
  r3 = native_call n0 [r2]
  print r3
  r4 = constant c2
  r5 = constant c3
  r6 = constant c4
  r7 = native_call n1 [r4, r5, r6]
  print r7
  r8 = constant c5
  r9 = constant c6
  r10 = native_call n2 [r8, r9]
  print r10
