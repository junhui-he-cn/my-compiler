cdbc 0.1

constants:
  c0 = number 1
  c1 = string "x"
  c2 = string "hello"
  c3 = number 1
  c4 = number 3
  c5 = string "hello"
  c6 = number 4

names:
  n0 = "str"
  n1 = "substr"
  n2 = "charAt"

main registers=11:
  r0 = constant c0
  r1 = constant c1
  r2 = array [r0, r1]
  r3 = native_call n0 [r2]
  print r3
  r4 = constant c2
  r5 = constant c3
  r6 = constant c4
  r7 = native_call n1 [r4, r5, r6]
  print r7
  r8 = constant c5
  r9 = constant c6
  r10 = native_call n2 [r8, r9]
  print r10

debug_sources:
  s0 path="tests/bytecode_artifacts/native_stdlib_strings/input.cd" text="print str([1, \"x\"]);\nprint substr(\"hello\", 1, 3);\nprint charAt(\"hello\", 4);\n"

debug_locations:
  main 0 = s0:1:12
  main 1 = s0:1:15
  main 2 = s0:1:11
  main 3 = s0:1:7
  main 4 = s0:1:1
  main 5 = s0:2:14
  main 6 = s0:2:23
  main 7 = s0:2:26
  main 8 = s0:2:7
  main 9 = s0:2:1
  main 10 = s0:3:14
  main 11 = s0:3:23
  main 12 = s0:3:7
  main 13 = s0:3:1
