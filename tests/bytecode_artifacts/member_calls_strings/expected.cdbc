cdbc 0.1

constants:
  c0 = string "hello"
  c1 = number 1
  c2 = number 3
  c3 = number 4

names:
  n0 = "text#0"
  n1 = "text#0"
  n2 = "text#0"
  n3 = "substr"
  n4 = "text#0"
  n5 = "charAt"

main registers=10:
  r0 = constant c0
  store_var n0, r0
  r1 = load_var n1
  r2 = len r1
  print r2
  r3 = load_var n2
  r4 = constant c1
  r5 = constant c2
  r6 = native_call n3 [r3, r4, r5]
  print r6
  r7 = load_var n4
  r8 = constant c3
  r9 = native_call n5 [r7, r8]
  print r9

debug_sources:
  s0 path="tests/bytecode_artifacts/member_calls_strings/input.cd" text="let text = \"hello\";\nprint text.len();\nprint text.substr(1, 3);\nprint text.charAt(4);\n"

debug_locations:
  main 0 = s0:1:12
  main 1 = s0:1:1
  main 2 = s0:2:7
  main 3 = s0:2:7
  main 4 = s0:2:1
  main 5 = s0:3:7
  main 6 = s0:3:19
  main 7 = s0:3:22
  main 8 = s0:3:7
  main 9 = s0:3:1
  main 10 = s0:4:7
  main 11 = s0:4:19
  main 12 = s0:4:7
  main 13 = s0:4:1
