cdbc 0.1

constants:
  c0 = string "hello"
  c1 = number 1
  c2 = number 3
  c3 = number 4

names:
  n0 = "text#0"
  n1 = "text#0"
  n2 = "text#0"
  n3 = "substr"
  n4 = "text#0"
  n5 = "charAt"

main registers=10:
  r0 = constant c0
  store_var n0, r0
  r1 = load_var n1
  r2 = len r1
  print r2
  r3 = load_var n2
  r4 = constant c1
  r5 = constant c2
  r6 = native_call n3 [r3, r4, r5]
  print r6
  r7 = load_var n4
  r8 = constant c3
  r9 = native_call n5 [r7, r8]
  print r9
