let values: [number] = [1, 2, 3];
let double = fun (value: number): number { return value * 2; };
let doubled = map(values, double);
let offset: number = 5;
let shifted = values.map(fun (value: number): number { return value + offset; });
let text = map(values, fun (value: number): string { return str(value); });

print doubled;
print shifted;
print text;
