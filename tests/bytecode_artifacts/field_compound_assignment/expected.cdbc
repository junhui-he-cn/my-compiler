cdbc 0.1

constants:
  c0 = number 1
  c1 = number 2

names:
  n0 = "Counter"
  n1 = "value"
  n2 = "c#0"
  n3 = "c#0"
  n4 = "value"
  n5 = "`+=` expects number target"
  n6 = "`+=` expects number value"
  n7 = "value"
  n8 = "c#0"
  n9 = "value"

main registers=11:
  r0 = constant c0
  r1 = struct n0 {n1: r0}
  store_var n2, r1
  r2 = load_var n3
  r3 = field r2, n4
  r4 = assert_number r3, n5
  r5 = constant c1
  r6 = assert_number r5, n6
  r7 = add r4, r6
  r8 = assign_field r2, n7, r7
  r9 = load_var n8
  r10 = field r9, n9
  print r10

debug_sources:
  s0 path="tests/bytecode_artifacts/field_compound_assignment/input.cd" text="struct Counter { value: number }\nlet c: Counter = Counter { value: 1 };\nc.value += 2;\nprint c.value;\n"

debug_locations:
  main 0 = s0:2:35
  main 1 = s0:2:18
  main 2 = s0:2:1
  main 3 = s0:3:1
  main 4 = s0:3:1
  main 5 = s0:3:1
  main 6 = s0:3:12
  main 7 = s0:3:1
  main 8 = s0:3:1
  main 9 = s0:3:1
  main 10 = s0:4:7
  main 11 = s0:4:7
  main 12 = s0:4:1
