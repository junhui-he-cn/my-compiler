cdbc 0.1

constants:
  c0 = number 1
  c1 = number 2

names:
  n0 = "Counter"
  n1 = "value"
  n2 = "c#0"
  n3 = "c#0"
  n4 = "value"
  n5 = "`+=` expects number target"
  n6 = "`+=` expects number value"
  n7 = "value"
  n8 = "c#0"
  n9 = "value"

main registers=11:
  r0 = constant c0
  r1 = struct n0 {n1: r0}
  store_var n2, r1
  r2 = load_var n3
  r3 = field r2, n4
  r4 = assert_number r3, n5
  r5 = constant c1
  r6 = assert_number r5, n6
  r7 = add r4, r6
  r8 = assign_field r2, n7, r7
  r9 = load_var n8
  r10 = field r9, n9
  print r10
