cdbc 0.1

constants:
  c0 = string "Ada"
  c1 = number 36
  c2 = number 1
  c3 = string "p"

names:
  n0 = "Person"
  n1 = "name"
  n2 = "age"
  n3 = "person#0"
  n4 = "person#0"
  n5 = "name"
  n6 = "Nested"
  n7 = "point"
  n8 = "Point"
  n9 = "x"
  n10 = "label"
  n11 = "nested#1"
  n12 = "nested#1"
  n13 = "point"
  n14 = "x"

main registers=12:
  r0 = constant c0
  r1 = constant c1
  r2 = struct n0 {n1: r0, n2: r1}
  store_var n3, r2
  r3 = load_var n4
  r4 = field r3, n5
  print r4
  r5 = constant c2
  r6 = struct n8 {n9: r5}
  r7 = constant c3
  r8 = struct n6 {n7: r6, n10: r7}
  store_var n11, r8
  r9 = load_var n12
  r10 = field r9, n13
  r11 = field r10, n14
  print r11

debug_sources:
  s0 path="tests/bytecode_artifacts/structs/input.cd" text="struct Person { name: string, age: number }\nstruct Point { x: number }\nstruct Nested { point: Point, label: string }\nlet person = Person { name: \"Ada\", age: 36 };\nprint person.name;\nlet nested = Nested { point: Point { x: 1 }, label: \"p\" };\nprint nested.point.x;\n"

debug_locations:
  main 0 = s0:4:29
  main 1 = s0:4:41
  main 2 = s0:4:14
  main 3 = s0:4:1
  main 4 = s0:5:7
  main 5 = s0:5:7
  main 6 = s0:5:1
  main 7 = s0:6:41
  main 8 = s0:6:30
  main 9 = s0:6:53
  main 10 = s0:6:14
  main 11 = s0:6:1
  main 12 = s0:7:7
  main 13 = s0:7:7
  main 14 = s0:7:7
  main 15 = s0:7:1
