cdbc 0.1

constants:
  c0 = number 4
  c1 = number 4
  c2 = number 0
  c3 = number 0

names:
  n0 = "Option"
  n1 = "Some"
  n2 = "value#0"
  n3 = "value#0"
  n4 = "Option"
  n5 = "Some"
  n6 = "number#1"
  n7 = "number#1"
  n8 = "number#1"
  n9 = "Option"
  n10 = "Some"
  n11 = "Option"
  n12 = "None"

main registers=15:
  r0 = constant c0
  r1 = variant n0.n1 [r0]
  store_var n2, r1
  r2 = load_var n3
  r4 = variant_tag r2 n4.n5
  jump_if_false r4, 15
  r5 = variant_field r2 0
  store_var n6, r5
  r6 = load_var n7
  r7 = constant c1
  r8 = greater r6, r7
  jump_if_false r8, 15
  r9 = load_var n8
  r3 = move r9
  jump 26
  r10 = variant_tag r2 n9.n10
  jump_if_false r10, 21
  r11 = variant_field r2 0
  r12 = constant c2
  r3 = move r12
  jump 26
  r13 = variant_tag r2 n11.n12
  jump_if_false r13, 26
  r14 = constant c3
  r3 = move r14
  jump 26
  print r3

debug_sources:
