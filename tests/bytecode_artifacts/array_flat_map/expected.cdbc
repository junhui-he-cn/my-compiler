cdbc 0.1

constants:
  c0 = number 1
  c1 = number 2
  c2 = number 10
  c3 = nil
  c4 = number 1
  c5 = nil

names:
  n0 = "values#0"
  n1 = "values#0"
  n2 = "value#1"
  n3 = "value#1"
  n4 = "flatMap"
  n5 = "values#0"
  n6 = "value#2"
  n7 = "flatMap"

main registers=9:
  r0 = constant c0
  r1 = constant c1
  r2 = array [r0, r1]
  store_var n0, r2
  r3 = load_var n1
  r4 = make_function f0
  r5 = native_call n4 [r3, r4]
  print r5
  r6 = load_var n5
  r7 = make_function f1
  r8 = native_call n7 [r6, r7]
  print r8

function f0 name="<lambda>" arity=1 registers=6:
  param 0 = "value#1"
  r0 = load_var n2
  r1 = load_var n3
  r2 = constant c2
  r3 = multiply r1, r2
  r4 = array [r0, r3]
  return r4
  r5 = constant c3
  return r5

function f1 name="<lambda>" arity=1 registers=5:
  param 0 = "value#2"
  r0 = load_var n6
  r1 = constant c4
  r2 = add r0, r1
  r3 = array [r2]
  return r3
  r4 = constant c5
  return r4

