cdbc 0.1

constants:
  c0 = number 4.8
  c1 = number 4.2
  c2 = number 25

names:
  n0 = "floor"
  n1 = "ceil"
  n2 = "sqrt"

main registers=6:
  r0 = constant c0
  r1 = native_call n0 [r0]
  print r1
  r2 = constant c1
  r3 = native_call n1 [r2]
  print r3
  r4 = constant c2
  r5 = native_call n2 [r4]
  print r5

debug_sources:
  s0 path="tests/bytecode_artifacts/native_stdlib_math/input.cd" text="print floor(4.8);\nprint ceil(4.2);\nprint sqrt(25);\n"

debug_locations:
  main 0 = s0:1:13
  main 1 = s0:1:7
  main 2 = s0:1:1
  main 3 = s0:2:12
  main 4 = s0:2:7
  main 5 = s0:2:1
  main 6 = s0:3:12
  main 7 = s0:3:7
  main 8 = s0:3:1
