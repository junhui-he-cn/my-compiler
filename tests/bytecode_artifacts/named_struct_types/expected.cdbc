cdbc 0.1

constants:
  c0 = string "Ada"
  c1 = number 36
  c2 = number 37

names:
  n0 = "Person"
  n1 = "name"
  n2 = "age"
  n3 = "p#0"
  n4 = "p#0"
  n5 = "age"
  n6 = "p#0"
  n7 = "name"
  n8 = "p#0"
  n9 = "age"

main registers=10:
  r0 = constant c0
  r1 = constant c1
  r2 = struct n0 {n1: r0, n2: r1}
  store_var n3, r2
  r3 = load_var n4
  r4 = constant c2
  r5 = assign_field r3, n5, r4
  r6 = load_var n6
  r7 = field r6, n7
  print r7
  r8 = load_var n8
  r9 = field r8, n9
  print r9

debug_sources:
  s0 path="tests/bytecode_artifacts/named_struct_types/input.cd" text="struct Person { name: string, age: number }\nlet p: Person = Person { name: \"Ada\", age: 36 };\np.age = 37;\nprint p.name;\nprint p.age;\n"

debug_locations:
  main 0 = s0:2:32
  main 1 = s0:2:44
  main 2 = s0:2:17
  main 3 = s0:2:1
  main 4 = s0:3:1
  main 5 = s0:3:9
  main 6 = s0:3:1
  main 7 = s0:4:7
  main 8 = s0:4:7
  main 9 = s0:4:1
  main 10 = s0:5:7
  main 11 = s0:5:7
  main 12 = s0:5:1
