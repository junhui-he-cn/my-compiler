cdbc 0.1

constants:
  c0 = string "Ada"
  c1 = number 36
  c2 = number 37

names:
  n0 = "name"
  n1 = "age"
  n2 = "p#0"
  n3 = "p#0"
  n4 = "age"
  n5 = "p#0"
  n6 = "name"
  n7 = "p#0"
  n8 = "age"

main registers=10:
  r0 = constant c0
  r1 = constant c1
  r2 = struct {n0: r0, n1: r1}
  store_var n2, r2
  r3 = load_var n3
  r4 = constant c2
  r5 = assign_field r3, n4, r4
  r6 = load_var n5
  r7 = field r6, n6
  print r7
  r8 = load_var n7
  r9 = field r8, n8
  print r9
