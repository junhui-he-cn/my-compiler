debug_sources:
  s0 path="tests/bytecode_artifacts/literal_patterns/input.cd" text="enum Result {\n  Number(value: number),\n  Text(value: string),\n  Empty,\n}\n\nfun describeNumber(value: number): string {\n  match value {\n    0 => { return \"zero\"; }\n    1 => { return \"one\"; }\n    _ => { return \"many\"; }\n  }\n}\n\nfun describeBool(value: bool): string {\n  match value {\n    true => { return \"true\"; }\n    false => { return \"false\"; }\n  }\n}\n\nfun describeResult(value: Result?): string {\n  match value {\n    nil => { return \"nil\"; }\n    Result.Number(0) => { return \"zero\"; }\n    Result.Number(value) => { return \"number:\" + str(value); }\n    Result.Text(\"\") => { return \"empty-text\"; }\n    Result.Text(value) => { return \"text:\" + value; }\n    Result.Empty => { return \"empty\"; }\n  }\n}\n\nlet maybe: bool? = nil;\nprint describeNumber(0);\nprint describeNumber(8);\nprint describeBool(false);\nprint describeResult(Result.Number(7));\nprint describeResult(Result.Text(\"\"));\nprint describeResult(nil);\nprint match 1 {\n  0 => \"zero\",\n  1 => \"one\",\n  _ => \"many\",\n};\nprint match true {\n  false => \"no\",\n  true => \"yes\",\n};\nprint match \"ok\" {\n  \"\" => \"empty\",\n  \"ok\" => \"ok\",\n  _ => \"other\",\n};\nprint match maybe {\n  nil => \"nil\",\n  true => \"true\",\n  false => \"false\",\n};\n"

