cdbc 0.1

constants:
  c0 = number 2
  c1 = number 4
  c2 = number 10
  c3 = number 0

names:
  n0 = "Pair"
  n1 = "Values"
  n2 = "pair#0"
  n3 = "pair#0"
  n4 = "Pair"
  n5 = "Values"
  n6 = "rightValue#1"
  n7 = "leftValue#2"
  n8 = "rightValue#1"
  n9 = "leftValue#2"
  n10 = "Pair"
  n11 = "Empty"

main registers=15:
  r0 = constant c0
  r1 = constant c1
  r2 = variant n0.n1 [r0, r1]
  store_var n2, r2
  r3 = load_var n3
  r5 = variant_tag r3 n4.n5
  jump_if_false r5, 18
  r6 = variant_field r3 1
  r7 = variant_field r3 0
  store_var n6, r6
  store_var n7, r7
  r8 = load_var n8
  r9 = constant c2
  r10 = multiply r8, r9
  r11 = load_var n9
  r12 = add r10, r11
  r4 = move r12
  jump 23
  r13 = variant_tag r3 n10.n11
  jump_if_false r13, 23
  r14 = constant c3
  r4 = move r14
  jump 23
  print r4

debug_sources:
  s0 path="tests/bytecode_artifacts/named_payload_fields/input.cd" text="enum Pair { Values(left: number, right: number), Empty }\nlet pair = Pair.Values(2, 4);\nprint match pair {\n  Pair.Values(right: rightValue, left: leftValue) => rightValue * 10 + leftValue,\n  Pair.Empty => 0,\n};\n"

