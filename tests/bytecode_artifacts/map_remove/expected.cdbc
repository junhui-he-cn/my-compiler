  main 7 = s0:2:1
  main 8 = s0:3:14
  main 9 = s0:3:22
  main 10 = s0:3:7
  main 11 = s0:3:1
  main 12 = s0:4:7
  main 13 = s0:4:1
  main 14 = s0:5:7
  main 15 = s0:5:20
  main 16 = s0:5:7
  main 17 = s0:5:1
