cdbc 0.1

constants:
  c0 = string "a"
  c1 = number 1
  c2 = string "b"
  c3 = number 2
  c4 = string "a"
  c5 = string "b"

names:
  n0 = "values#0"
  n1 = "values#0"
  n2 = "alias#1"
  n3 = "values#0"
  n4 = "remove"
  n5 = "alias#1"
  n6 = "alias#1"
  n7 = "remove"
  n8 = "values#0"

main registers=15:
  r0 = constant c0
  r1 = constant c1
  r2 = constant c2
  r3 = constant c3
  r4 = map [r0: r1, r2: r3]
  store_var n0, r4
  r5 = load_var n1
  store_var n2, r5
  r6 = load_var n3
  r7 = constant c4
  r8 = native_call n4 [r6, r7]
  print r8
  r9 = load_var n5
  print r9
  r10 = load_var n6
  r11 = constant c5
  r12 = native_call n7 [r10, r11]
  print r12
  r13 = load_var n8
  r14 = len r13
  print r14

debug_sources:
  s0 path="tests/bytecode_artifacts/map_remove/input.cd" text="let values = {\"a\": 1, \"b\": 2};\nlet alias = values;\nprint remove(values, \"a\");\nprint alias;\nprint alias.remove(\"b\");\nprint values.len();\n"

debug_locations:
