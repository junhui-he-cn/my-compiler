debug_sources:
  s0 path="tests/bytecode_artifacts/generic_enums/input.cd" text="enum Option<T> {\n  Some(value: T),\n  None,\n}\n\nenum List<T> {\n  Nil,\n  Cons(head: T, tail: List<T>),\n}\n\nfun describe(value: Option<number>): string {\n  return match value {\n    Option.Some(value: numberValue) => \"some:\" + str(numberValue),\n    Option.None => \"none\",\n  };\n}\n\nfun sum(list: List<number>): number {\n  return match list {\n    List.Nil => 0,\n    List.Cons(head: first, tail: rest) => first + sum(rest),\n  };\n}\n\nlet some: Option<number> = Option.Some(7);\nlet none: Option<number> = Option.None<number>();\nlet maybe: Option<number>? = nil;\nlet inferred = Option.Some(\"hello\");\nprint describe(some);\nprint describe(none);\nprint sum(List.Cons(1, List.Cons(2, List.Nil<number>())));\nprint match maybe {\n  nil => \"nil\",\n  Option.Some(value) => \"some\",\n  Option.None => \"none\",\n};\nprint match inferred {\n  Option.Some(value) => value,\n  Option.None => \"none\",\n};\n"

