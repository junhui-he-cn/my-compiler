cdbc 0.1

constants:
  c0 = number 1
  c1 = number 0
  c2 = number 2
  c3 = number 0

names:
  n0 = "xs#0"
  n1 = "xs#0"
  n2 = "`+=` expects number target"
  n3 = "`+=` expects number value"
  n4 = "xs#0"

main registers=13:
  r0 = constant c0
  r1 = array [r0]
  store_var n0, r1
  r2 = load_var n1
  r3 = constant c1
  r4 = index r2, r3
  r5 = assert_number r4, n2
  r6 = constant c2
  r7 = assert_number r6, n3
  r8 = add r5, r7
  r9 = assign_index r2, r3, r8
  r10 = load_var n4
  r11 = constant c3
  r12 = index r10, r11
  print r12

debug_sources:
  s0 path="tests/bytecode_artifacts/index_compound_assignment/input.cd" text="let xs: [number] = [1];\nxs[0] += 2;\nprint xs[0];\n"

debug_locations:
  main 0 = s0:1:21
  main 1 = s0:1:20
  main 2 = s0:1:1
  main 3 = s0:2:1
  main 4 = s0:2:4
  main 5 = s0:2:1
  main 6 = s0:2:1
  main 7 = s0:2:10
  main 8 = s0:2:1
  main 9 = s0:2:1
  main 10 = s0:2:1
  main 11 = s0:3:7
  main 12 = s0:3:10
  main 13 = s0:3:7
  main 14 = s0:3:1
