debug_sources:
  s0 path="tests/bytecode_artifacts/or_patterns/input.cd" text="enum Shape {\n  Point(x: number),\n  Line(x: number, y: number),\n  Empty,\n}\n\nfun numberLabel(value: number): string {\n  return match value {\n    0 | 1 => \"small\",\n    _ => \"other\",\n  };\n}\n\nfun shapeLabel(value: Shape): string {\n  return match value {\n    Shape.Point(x) | Shape.Line(x, _) if x > 3 => \"large:\" + str(x),\n    Shape.Point(_) | Shape.Line(_, _) => \"small\",\n    Shape.Empty => \"empty\",\n  };\n}\n\nlet maybe: bool? = false;\nprint numberLabel(1);\nprint numberLabel(8);\nprint shapeLabel(Shape.Point(3));\nprint shapeLabel(Shape.Line(4, 10));\nprint shapeLabel(Shape.Empty());\nprint match maybe {\n  nil | false => \"off\",\n  true => \"on\",\n};\nprint match true {\n  true | false => \"bool\",\n};\n"

