Program
  Enum Result {Ok(number), Err(string), Empty}
  Enum List {Nil, Cons(number, List)}
  Fun describe(result: Result): string
    Return (match result (arm Result.Ok(value) (+ "ok:" (call str value))) (arm Result.Err(message) (+ "err:" message)) (arm Result.Empty "empty"))
  Fun sum(list: List): number
    Return (match list (arm List.Nil 0) (arm List.Cons(head, List.Cons(next, tail)) (+ (+ head next) (call sum tail))) (arm List.Cons(head, List.Nil) head))
  Let result = (member-call Result Ok 7)
  Print (call describe result)
  Print (call sum (member-call List Cons 1 (member-call List Cons 2 (member-call List Nil))))
  Print (match result (arm Result.Ok(_) "ok") (arm _ "other"))
