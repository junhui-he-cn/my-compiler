enum Result {
  Ok(number),
  Err(string),
  Empty,
}

enum List {
  Nil,
  Cons(number, List),
}

fun describe(result: Result): string {
  return match result {
    Result.Ok(value) => "ok:" + str(value),
    Result.Err(message) => "err:" + message,
    Result.Empty => "empty",
  };
}

fun sum(list: List): number {
  return match list {
    List.Nil => 0,
    List.Cons(head, List.Cons(next, tail)) => head + next + sum(tail),
    List.Cons(head, List.Nil) => head,
  };
}

let result = Result.Ok(7);
print describe(result);
print sum(List.Cons(1, List.Cons(2, List.Nil())));
print match result {
  Result.Ok(_) => "ok",
  _ => "other",
};
