Program
  Let prices: map<string, number> = (map (entry "tea" 3) (entry "coffee" 5))
  Print (index prices "tea")
  Let alias = prices
  Expr (= (index alias "water") 2)
  Print (index prices "water")
  Print (call len prices)
  Print (member-call prices len)
  Print (call contains prices "coffee")
  Print (member-call prices contains "tea")
  Let empty = (map)
  Expr (= (index empty "new") 1)
  Print (member-call empty len)
  Print (index empty "new")
  Let primitives = (map (entry nil "nil") (entry true "bool") (entry 1 "number") (entry "text" "string"))
  Print (index primitives nil)
  Print (index primitives true)
  Print (index primitives 1)
  Print (index primitives "text")
  Let duplicates = (map (entry "a" 1) (entry "a" 2))
  Print (index duplicates "a")
  Print (group (= (index duplicates "b") 3))
  Print duplicates
  Let nested: map<string, map<string, number>> = (map (entry "inner" (map (entry "value" 7))))
  Print (index (index nested "inner") "value")
  Let nullable: map<string, number?> = (map (entry "present" 1) (entry "missing" nil))
  Print (index nullable "missing")
  Let same = duplicates
  Let other = (map (entry "a" 2) (entry "b" 3))
  Print (== duplicates same)
  Print (== duplicates other)
  Print (call typeOf duplicates)
