main registers=10
0000  b0 = constant #0 "Ada"
0001  b1 = constant #1 36
0002  b2 = struct { @0 name: b0,  @1 age: b1}
0003  store_var @2 p#0, b2
0004  b3 = load_var @3 p#0
0005  b4 = field b3,  @4 name
0006  print b4
0007  b5 = load_var @5 p#0
0008  b6 = constant #2 37
0009  b7 = assign_field b5,  @6 age, b6
0010  b8 = load_var @7 p#0
0011  b9 = field b8,  @8 age
0012  print b9
