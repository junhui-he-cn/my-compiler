Program
  Let values: [number] = (array 4 7 9)
  Print (call findIndex values (fun (value: number): bool (return (> value 6))))
  Print (member-call values findIndex (fun (value: number): bool (return (== value 2))))
  Let snapshot: [number] = (array 1 2)
  Print (member-call snapshot findIndex (fun (value: number): bool (expr (call push snapshot 9)) (return (== value 2))))
  Print snapshot
  Print (member-call (array) findIndex (fun (value: number): bool (return true)))
