main registers=4
0000  b0 = make_function $0 <lambda>/1
0001  store_var @1 inc#1, b0
0002  b1 = load_var @2 inc#1
0003  b2 = constant #2 41
0004  b3 = call b1(b2)
0005  print b3

function $0 <lambda>/1 registers=4
0000  b0 = load_var @0 x#0
0001  b1 = constant #0 1
0002  b2 = add b0, b1
0003  return b2
0004  b3 = constant #1 nil
0005  return b3
