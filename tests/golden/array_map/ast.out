Program
  Let values: [number] = (array 1 2 3)
  Let double = (fun (value: number): number (return (* value 2)))
  Let doubled = (call map values double)
  Let offset: number = 5
  Let shifted = (member-call values map (fun (value: number): number (return (+ value offset))))
  Let text = (call map values (fun (value: number): string (return (call str value))))
  Print doubled
  Print shifted
  Print text
