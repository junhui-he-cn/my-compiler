main registers=16
0000  b0 = constant #0 "Ada"
0001  b1 = constant #1 36
0002  b2 = struct { @0 name: b0,  @1 age: b1}
0003  store_var @2 person#0, b2
0004  b3 = load_var @3 person#0
0005  b4 = field b3,  @4 name
0006  print b4
0007  b5 = load_var @5 person#0
0008  b6 = field b5,  @6 age
0009  print b6
0010  b7 = constant #2 1
0011  b8 = constant #3 2
0012  b9 = struct { @8 x: b7,  @9 y: b8}
0013  b10 = constant #4 "p"
0014  b11 = struct { @7 point: b9,  @10 label: b10}
0015  store_var @11 nested#1, b11
0016  b12 = load_var @12 nested#1
0017  b13 = field b12,  @13 point
0018  b14 = field b13,  @14 x
0019  print b14
0020  b15 = struct {}
0021  print b15
