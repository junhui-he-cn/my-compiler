Program
  Struct Person {name: string, age: number}
  Struct Point {x: number, y: number}
  Struct Nested {point: Point, label: string}
  Struct Empty {}
  Let person = (construct Person name: "Ada" age: 36)
  Print (field person name)
  Print (field person age)
  Let nested = (construct Nested point: (construct Point x: 1 y: 2) label: "p")
  Print (field (field nested point) x)
  Print (construct Empty)
