Program
  Module 0
    Struct Box<T: number> {value: T}
    Export Box
  Module 1 entry
    Import "lib.cd"
    Import "lib.cd" as lib
    Let direct: Box<number> = (construct Box<number> value: 1)
    Let namespaced: lib.Box<number> = (construct lib.Box<number> value: 2)
    Print (field direct value)
    Print (field namespaced value)
    Print (call typeOf namespaced)
