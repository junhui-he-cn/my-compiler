main registers=10
0000  b0 = constant #0 1
0001  b1 = struct @0 Box { @1 value: b0}
0002  store_var @2 direct#0, b1
0003  b2 = constant #1 2
0004  b3 = struct @3 lib.Box { @4 value: b2}
0005  store_var @5 namespaced#1, b3
0006  b4 = load_var @6 direct#0
0007  b5 = field b4,  @7 value
0008  print b5
0009  b6 = load_var @8 namespaced#1
0010  b7 = field b6,  @9 value
0011  print b7
0012  b8 = load_var @10 namespaced#1
0013  b9 = native_call @11 typeOf [b8]
0014  print b9
