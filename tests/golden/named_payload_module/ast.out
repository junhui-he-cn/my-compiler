Program
  Module 0
    Enum Outcome {Good(message: string), Bad(code: number)}
    Fun make(): Outcome
      Return (member-call Outcome Good "ok")
    Export Outcome make
  Module 1 entry
    Import "./lib.cd" as lib
    Fun render(value: lib.Outcome): string
      Return (match value (arm lib.Outcome.Good(message: text) text) (arm lib.Outcome.Bad(code: numberValue) (call str numberValue)))
    Print (call render (member-call lib make))
