struct Box { value: number }

impl Box {
  fun echo<T>(value: T): T {
    let copy: T = value;
    return copy;
  }

  fun head<T>(values: [T]): T {
    return values[0];
  }

  fun make<T>(): T? {
    return nil;
  }
}

let box: Box = Box { value: 0 };
print box.echo<number>(42);
print box.echo("hello");
print box.head<number>([3, 4]);
print box.make<string>();
