struct Address { city: string, zip: number }
struct Person { name: string, age: number, address: Address }

fun describe(value: Person?): string {
  return match value {
    nil => "nil",
    Person { name: "Ada" } => "ada",
    Person { address: Address { city: "Hong Kong" }, name: name } => "city:" + name,
    Person { age: age, name: name } => name + ":" + str(age),
  };
}

let ada = Person {
  name: "Ada",
  age: 36,
  address: Address { city: "Cambridge", zip: 1 }
};
let hongKong = Person {
  name: "Grace",
  age: 40,
  address: Address { city: "Hong Kong", zip: 2 }
};
let nilPerson: Person? = nil;
print describe(ada);
print describe(hongKong);
print describe(nilPerson);
print match ada {
  Person { name: "Ada" } | Person { age: 0 } => "or",
  Person {} => "fallback",
};
