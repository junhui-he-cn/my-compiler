IR
0000  v0 = constant #0 "hello"
0001  store_var @0 text#0, v0
0002  v1 = load_var @1 text#0
0003  v2 = len v1
0004  print v2
0005  v3 = load_var @2 text#0
0006  v4 = constant #1 1
0007  v5 = constant #2 3
0008  v6 = native_call @3 substr(v3, v4, v5)
0009  print v6
0010  v7 = load_var @4 text#0
0011  v8 = constant #3 4
0012  v9 = native_call @5 charAt(v7, v8)
0013  print v9
0014  v10 = constant #4 "abc"
0015  v11 = constant #5 "def"
0016  v12 = add v10, v11
0017  v13 = constant #6 2
0018  v14 = constant #7 3
0019  v15 = native_call @6 substr(v12, v13, v14)
0020  print v15
0021  v16 = constant #8 "xy"
0022  v17 = constant #9 "z"
0023  v18 = add v16, v17
0024  v19 = constant #10 1
0025  v20 = native_call @7 charAt(v18, v19)
0026  print v20
