Program
  Let person = {name: "Ada", age: 36}
  Expr (= (field person age) 37)
  Print (field person age)
  Print (= (field person age) 38)
  Let outer = {inner: {x: 1}}
  Expr (= (field (field outer inner) x) 2)
  Print (field (field outer inner) x)
  Let a = {x: 1}
  Let b = a
  Expr (= (field b x) 3)
  Print (field a x)
