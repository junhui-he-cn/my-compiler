main registers=29
0000  b0 = constant #0 "Ada"
0001  b1 = constant #1 36
0002  b2 = struct @0 Person { @1 name: b0,  @2 age: b1}
0003  store_var @3 person#0, b2
0004  b3 = load_var @4 person#0
0005  b4 = constant #2 37
0006  b5 = assign_field b3,  @5 age, b4
0007  b6 = load_var @6 person#0
0008  b7 = field b6,  @7 age
0009  print b7
0010  b8 = load_var @8 person#0
0011  b9 = constant #3 38
0012  b10 = assign_field b8,  @9 age, b9
0013  print b10
0014  b11 = constant #4 1
0015  b12 = struct @12 Inner { @13 x: b11}
0016  b13 = struct @10 Outer { @11 inner: b12}
0017  store_var @14 outer#1, b13
0018  b14 = load_var @15 outer#1
0019  b15 = field b14,  @16 inner
0020  b16 = constant #5 2
0021  b17 = assign_field b15,  @17 x, b16
0022  b18 = load_var @18 outer#1
0023  b19 = field b18,  @19 inner
0024  b20 = field b19,  @20 x
0025  print b20
0026  b21 = constant #6 1
0027  b22 = struct @21 Box { @22 x: b21}
0028  store_var @23 a#2, b22
0029  b23 = load_var @24 a#2
0030  store_var @25 b#3, b23
0031  b24 = load_var @26 b#3
0032  b25 = constant #7 3
0033  b26 = assign_field b24,  @27 x, b25
0034  b27 = load_var @28 a#2
0035  b28 = field b27,  @29 x
0036  print b28
