Program
  Let push = (fun (array, value) (print "custom push"))
  Let pop = (fun (array) (print "custom pop") (return 99))
  Let len = (fun (value) (return 123))
  Let substr = (fun (value, start, length) (return "custom substr"))
  Let charAt = (fun (value, index) (return "custom charAt"))
  Let xs = (array)
  Expr (member-call xs push 10)
  Print (member-call xs len)
  Print (member-call xs pop)
  Let text = "hello"
  Print (member-call text len)
  Print (member-call text substr 1 2)
  Print (member-call text charAt 1)
  Print (call len text)
  Print (call substr text 1 2)
  Print (call charAt text 1)
