Program
  Struct Box {value: number}
  Let xs: [number] = (array 1 2 3)
  Print (call contains xs 2)
  Print (member-call xs contains 4)
  Let shared = (array 9)
  Let nested = (array shared)
  Print (member-call nested contains shared)
  Print (member-call nested contains (array 9))
  Let box = (construct Box value: 1)
  Print (member-call (array box) contains box)
  Print (member-call (array box) contains (construct Box value: 1))
  Let part = (call slice xs 1 2)
  Print part
  Expr (= (index part 0) 20)
  Print xs
  Print (member-call xs slice 3 0)
  Let cloned = (call copy xs)
  Expr (= (index cloned 0) 10)
  Print xs
  Print cloned
  Let inner = (array 1)
  Let outer = (array inner)
  Let outerCopy = (member-call outer copy)
  Expr (member-call (index outerCopy 0) push 2)
  Print outer
  Print (call concat xs (array 4 5))
  Print (member-call xs concat (array))
  Let copy = (fun (value) (return value))
  Print (call copy 7)
  Print (member-call xs copy)
