let any = fun (array, predicate) {
  return "shadowed any";
};
let all = fun (array, predicate) {
  return "shadowed all";
};

print any([1], fun (value) { return true; });
print all([1], fun (value) { return true; });
print [1].any(fun (value) { return true; });
print [1].all(fun (value) { return true; });
