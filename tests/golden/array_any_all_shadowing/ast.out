Program
  Let any = (fun (array, predicate) (return "shadowed any"))
  Let all = (fun (array, predicate) (return "shadowed all"))
  Print (call any (array 1) (fun (value) (return true)))
  Print (call all (array 1) (fun (value) (return true)))
  Print (member-call (array 1) any (fun (value) (return true)))
  Print (member-call (array 1) all (fun (value) (return true)))
