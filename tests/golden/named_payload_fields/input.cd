enum Pair {
  Values(left: number, right: number),
  Empty,
}

enum Result {
  Ok(value: number),
  Err(message: string),
  Empty,
}

enum Box {
  Wrap(item: Result),
}

fun pairScore(pair: Pair): number {
  return match pair {
    Pair.Values(right: rightValue, left: leftValue) => rightValue * 10 + leftValue,
    Pair.Empty => 0,
  };
}

fun describe(result: Result): string {
  return match result {
    Result.Ok(value: numberValue) => "ok:" + str(numberValue),
    Result.Err(message: text) => "err:" + text,
    Result.Empty => "empty",
  };
}

fun unwrap(box: Box): string {
  return match box {
    Box.Wrap(item: Result.Ok(value: numberValue)) => str(numberValue),
    Box.Wrap(item: Result.Err(message: text)) => text,
    Box.Wrap(item: Result.Empty) => "empty",
  };
}

print pairScore(Pair.Values(2, 4));
print describe(Result.Ok(7));
print describe(Result.Err("bad"));
print describe(Result.Empty());
print unwrap(Box.Wrap(Result.Ok(9)));
