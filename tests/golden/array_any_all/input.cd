let values: [number] = [1, 2, 3];
let anyResult: bool = values.any(fun (value) {
  return value == 2;
});
let allResult: bool = all(values, fun (value: number): bool {
  return value < 4;
});

let snapshot: [number] = [1, 2, 3];
print any(snapshot, fun (value) {
  push(snapshot, 9);
  return value == 2;
});
print snapshot;

let allSnapshot: [number] = [1, 2, 3];
print allSnapshot.all(fun (value) {
  push(allSnapshot, 8);
  return value < 3;
});
print allSnapshot;

print [].any(fun (value: number): bool { return true; });
print [1, 2].all(fun (value: number): bool { return value > 0; });
