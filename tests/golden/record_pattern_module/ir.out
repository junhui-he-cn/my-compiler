IR
0000  v0 = constant #0 1
0001  v1 = constant #1 2
0002  v2 = struct geo.Point {x: v0, y: v1}
0003  store_var @3 point#0, v2
0004  v3 = load_var @4 point#0
0005  v5 = field v3.x
0006  v6 = constant #2 1
0007  v7 = equal v5, v6
0008  jump_if_false v7, 0012
0009  v8 = constant #3 "one"
0010  v4 = copy v8
0011  jump 0015
0012  v9 = constant #4 "other"
0013  v4 = copy v9
0014  jump 0015
0015  print v4
