main registers=10
0000  b0 = constant #0 1
0001  b1 = constant #1 2
0002  b2 = struct @0 geo.Point { @1 x: b0,  @2 y: b1}
0003  store_var @3 point#0, b2
0004  b3 = load_var @4 point#0
0005  b5 = field b3,  @5 x
0006  b6 = constant #2 1
0007  b7 = equal b5, b6
0008  jump_if_false b7, 0012
0009  b8 = constant #3 "one"
0010  b4 = move b8
0011  jump 0015
0012  b9 = constant #4 "other"
0013  b4 = move b9
0014  jump 0015
0015  print b4
