fun takesNumber(value: number): number { return value; }

let first: number? = 10;
let second: number? = 20;
if (first != nil && second != nil) {
  print takesNumber(first);
  print takesNumber(second);
}

let third: number? = 30;
let fourth: number? = 40;
if (third == nil || fourth == nil) {
  print 0;
} else {
  print takesNumber(third);
  print takesNumber(fourth);
}
