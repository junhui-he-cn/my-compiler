struct Box<T> { value: T }
struct NumberBox<T: number> { value: T }

impl Box<T> {
  fun get(): T {
    return this.value;
  }

  fun set(value: T): T {
    this.value = value;
    return this.value;
  }

  fun wrap<U>(value: U): Box<U> {
    return Box<U> { value: value };
  }
}

impl NumberBox<T> {
  fun get(): T {
    return this.value;
  }
}

let box: Box<number> = Box { value: 1 };
let numberBox: NumberBox<number> = NumberBox { value: 3 };
print box.get();
print box.set(2);
print box.value;
let textBox = box.wrap<string>("text");
print textBox.value;
print box.wrap("inferred").value;
print numberBox.get();
print typeOf(textBox);
