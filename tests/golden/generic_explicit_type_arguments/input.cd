import "lib.cd" as lib;

fun identity<T>(value: T): T {
  return value;
}
fun head<T>(values: [T]): T {
  return values[0];
}
fun make<T>(): T? {
  return nil;
}
print identity<number>(42);
print identity<string>("hello");
print head<number>([1, 2]);
print identity<[number]>([3, 4]);
print make<number>();
let alias = identity;
print alias<bool>(true);
print lib.identity<number>(7);
