Program
  Fun identity<T>(value: T): T
    Return value
  Fun keep<T>(value: T): bool
    Return true
  Fun singleton<T>(value: T): [T]
    Return (array value)
  Fun keepAccumulator<T>(acc: T, value: number): T
    Return acc
  Let values: [number] = (array 1 2)
  Let copied: [number] = (call map values identity)
  Print copied
  Print (member-call values map identity)
  Print (call filter values keep)
  Print (member-call values any keep)
  Print (member-call values all keep)
  Print (member-call values count keep)
  Print (member-call values find keep)
  Print (member-call values findIndex keep)
  Print (call flatMap values singleton)
  Print (member-call values reduce 0 keepAccumulator)
  Print (call map values (fun <T>(value: T): T (return value)))
  Fun acceptsNullable<T>(value: T?): bool
    Return true
  Let nullableValues: [number?] = (array 1 nil)
  Print (member-call nullableValues all acceptsNullable)
  Fun identityArray<T>(value: [T]): [T]
    Return value
  Let nestedValues: [[number]] = (array (array 1) (array 2))
  Print (call map nestedValues identityArray)
