import "lib.cd";
import "lib.cd" as lib;
import "forward.cd" as forwarded;

let direct: Box<number> = Box<number> { value: 1 };
let namespaced: lib.Box<number> = lib.Box<number> { value: 2 };
let reexported: forwarded.Box<number> = forwarded.Box<number> { value: 3 };
print direct.get();
print namespaced.get();
print namespaced.wrap<string>("two").value;
print reexported.get();
