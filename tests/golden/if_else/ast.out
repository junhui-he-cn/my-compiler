Program
  Let ok = true
  If ok
    Then
      Block
        Print "then"
    Else
      Block
        Print "else"
  If false
    Then
      Block
        Print "bad"
    Else
      Block
        Print "fallback"
  If true
    Then
      Block
        Print "no else"
  If false
    Then
      Block
        Print "bad no else"
  Print "after no else"
